<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TVRemote" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FFD700</item>
        <item name="colorPrimaryVariant">#CC9900</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:windowBackground">#1A1A1A</item>
        <item name="android:statusBarColor">#111111</item>
    </style>

    <style name="RemoteBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:backgroundTint">#333333</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:gravity">center</item>
        <item name="android:lines">2</item>
    </style>

    <style name="NavBtn">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:backgroundTint">#444444</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="NumBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:backgroundTint">#2A2A2A</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>
